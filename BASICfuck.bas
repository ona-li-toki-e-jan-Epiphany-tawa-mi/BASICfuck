0 REM CONFIG.
10 CC% = 15000 - 1        : REM HOW MANY CELLS TO HAVE IN MEMORY.
15 REM INITIALIZATION.
18 DIM CM%(CC%)           : REM CELL MEMORY.
19 PS% = 510 - 1          : REM PROGRAM MEMORY SIZE.
20 DIM PM%(PS%)           : REM PROGRAM MEMORY.
30 CP% = 0                : REM CELL MEMORY POINTER.
32 AP = 0                 : REM C64 MEMORY POINTER.
34 DEF FN GI(X) = ASC(MID$(IN$, X, 1)) : REM GETS CHARACTER IN INPUT.
35 REM STARTUP MESSAGE.
38 PRINT CHR$(147);       : REM CLEARS SCREEN.
40 PRINT "BASICFUCK C64 BRAINFUCK REPL V1.0"
50 PRINT "TYPE ? FOR HELP."
60 PRINT "TYPE ! TO EXIT."
65 REM (GOTO 70) INPUT LOOP.
70 INPUT "$"; IN$
75 IF IN$ = "" THEN GOSUB 2010 : GOTO 70
80 FC$ = LEFT$(IN$, 1)
90 IF FC$ = "!" THEN END
100 IF FC$ = "?" THEN GOSUB 1010 : GOSUB 2010 : GOTO 70
110 REM CODE PARSING.
115 PP% = 0                             : REM PROGRAM POINTER.
118 IS% = LEN(IN$)                      : REM INPUT SIZE.
120 FOR I = 1 TO IS%
130 C% = FN GI(I)
140 IF C% = 43 THEN GOSUB 8010                   : GOTO 215 : REM +
150 IF C% = 45 THEN GOSUB 8010                   : GOTO 215 : REM -
160 IF C% = 60 THEN GOSUB 9010                   : GOTO 215 : REM <
170 IF C% = 62 THEN GOSUB 9010                   : GOTO 215 : REM >
180 IF C% = 91 THEN PM%(PP%) = 3 : PP% = PP% + 2 : GOTO 215 : REM [
190 IF C% = 93 THEN PM%(PP%) = 4 : PP% = PP% + 2 : GOTO 215 : REM ]
200 IF C% = 46 THEN PM%(PP%) = 5 : PP% = PP% + 2 : GOTO 215 : REM .
210 IF C% = 59 THEN PM%(PP%) = 6 : PP% = PP% + 2 : GOTO 215 : REM ;
211 IF C% = 40 THEN GOSUB 11010                  : GOTO 215 : REM (
212 IF C% = 41 THEN GOSUB 11010                  : GOTO 215 : REM )
213 IF C% = 64 THEN PM%(PP%) = 8 : PP% = PP% + 2 : GOTO 215 : REM @
214 IF C% = 42 THEN PM%(PP%) = 9 : PP% = PP% + 2 : GOTO 215 : REM *
215 NEXT I
220 IF PP% < PS% THEN PM%(PP%) = 0
225 REM SECOND PASS FOR PARSING JUMP POINTS.
228 F% = 0  : REM FAIL FLAG FOR PARSING UNTERMINATED LOOPS.
232 FOR PP = 0 TO PS% STEP 2
235 IN% = PM%(PP)
240 IF IN% = 0 THEN PP = PS% + 1 : GOTO 260
250 IF IN% = 3 OR IN% = 4 THEN GOSUB 10010
255 IF F% THEN PP = PS% + 1
260 NEXT PP
270 IF F% THEN PRINT "?UNTERMINATED LOOP" : GOTO 70
310 REM INTERPRETER.
315 K$ = ""
320 FOR PP = 0 TO PS% STEP 2
325 GET K$ : IF K$ <> "" THEN IF ASC(K$) = 133 THEN PP = PS% + 1 : GOTO 410
330 ON PM%(PP) GOTO 350, 360, 370, 380, 390, 400, 405, 408, 409
340 PP = PS% + 1 : GOTO 410
350 GOSUB 25010  : GOTO 410 : REM + AND -
360 GOSUB 26010  : GOTO 410 : REM < AND >
370 GOSUB 27010  : GOTO 410 : REM [
380 GOSUB 27510  : GOTO 410 : REM ]
390 GOSUB 28010  : GOTO 410 : REM .
400 GOSUB 29010  : GOTO 410 : REM ;
405 GOSUB 30010  : GOTO 410 : REM ( AND )
408 GOSUB 31010  : GOTO 410 : REM @
409 GOSUB 31510  : GOTO 410 : REM *
410 NEXT PP
420 GOSUB 2010 : GOTO 70
1000 REM (GOSUB 1010) HELP MESSAGES.
1010 PRINT " ! EXITS THE REPL. ? DISPLAYS HELP INFORMATION."
1030 PRINT "THE PREVIOUS TWO COMMANDS MUST BE THE FIRST CHARACTER IN INPUT TO";
1040 PRINT " FUNCTION"
1050 PRINT " +/- INCREMENTS/DECREMENTS THE CURRENT CELL."
1060 PRINT " </> MOVES THE MEMORY POINTER TO THE LEFT/RIGHT."
1070 PRINT " [ JUMPS PAST THE CORRESPONDING ] IF THE CURRENT CELL IS 0."
1080 PRINT " ] JUMPS TO THE CORRESPONDING [ IF THE CURRENT CELL IS NOT 0."
1090 PRINT " . PRINTS THE VALUE OF THE CURRENT CELL AS A CHARACTER."
1100 PRINT " ; TAKES ONE CHARACTER FROM THE KEYBOARD AS INPUT AND STORES IT ";
1110 PRINT "INTO THE CURRENT CELL."
1112 PRINT " (/) MOVES THE C64 MEMORY POINTER TO THE LEFT/RIGHT."
1115 PRINT " @ READS THE VALUE FROM C64 MEMORY INTO THE CURRENT CELL."
1118 PRINT " * PUTS THE VALUE OF THE CURRENT CELL INTO C64 MEMORY."
1120 RETURN
2000 REM (GOSUB 2010) PRINT CURRENT CELL.
2010 PRINT CM%(CP%);"(CELL";CP%;", $";AP;")"
2020 RETURN
3000 REM (GOSUB 3010) todo FOR WHATEVER
3050 RETURN
4000 REM (GOSUB 4010) todo FOR WHATEVER
5000 REM (GOSUB 5010) todo FOR WHATEVER.
5010 RETURN
8000 REM (GOSUB 8010) MAKE + AND - INSTRUCTIONS.
8010 RA% = 43 : RB% = 45 : GOSUB 12010    
8020 IF RA% = 0 GOTO 8060 : REM DOSEN'T STORE INSTUCTION IF IT DOES NOTHING.
8030 PM%(PP%) = 1
8040 PM%(PP%+1) = RA%
8050 PP% = PP% + 2 
8060 I = I - 1 : RETURN
9000 REM (GOSUB 9010) MAKE < AND > INSTRUCTIONS.
9010 RA% = 62 : RB% = 60 : GOSUB 12010
9020 IF RA% = 0 GOTO 9060 : REM DOSEN'T STORE INSTUCTION IF IT DOES NOTHING.
9030 PM%(PP%) = 2
9040 PM%(PP%+1) = RA%
9050 PP% = PP% + 2
9060 I = I - 1 : RETURN
10000 REM (GOSUB 10010) MAKE [ AND ] INSTRUCTIONS.
10010 B% = IN% : REM THE GIVEN BRACKET.
10012 IF B% = 3 THEN OB% = 4 : K = 2 : GOTO 10016
10013 OB% = 3  : REM THE CORRESPONDING BRACKET.
10014 K = -2   : REM INPUT ITERATOR STEP.
10016 PP% = PP
10019 D% = 0   : REM CURRENT LOOP DEPTH.
10020 PP% = PP% + K : IF PP% > PS% OR PP% < 0 THEN F% = -1 : GOTO 10080
10030 IN% = PM%(PP%)
10035 IF IN% = 0 THEN F% = -1 : GOTO 10080
10040 IF IN% = B% THEN D% = D% + 1 : GOTO 10020
10050 IF IN% <> OB% GOTO 10020
10060 IF D% > 0 THEN D% = D% - 1 : GOTO 10020
10070 PM%(PP+1) = PP%
10080 RETURN
11000 REM (GOSUB 11010) MAKE ( AND ) INSTRUCTIONS.
11010 RA% = 41 : RB% = 40 : GOSUB 12010
11020 IF RA% = 0 GOTO 11060 : REM DOSEN'T STORE INSTUCTION IF IT DOES NOTHING.
11030 PM%(PP%) = 7
11040 PM%(PP%+1) = RA%
11050 PP% = PP% + 2
11060 I = I - 1 : RETURN
12000 REM (GOSUB 12010) COUNT CHARACTERS +/-. RA% IS THE + CHAR., RB% IS -. 
12005 REM RESULT IS RA%.
12010 IC% = 0
12020 IF I > IS% GOTO 12090
12030 C% = FN GI(I)
12040 IF C% = RA% GOTO 12070
12050 IF C% = RB% GOTO 12080
12060 GOTO 12090
12070 IC% = IC% + 1 : I = I + 1 : GOTO 12020
12080 IC% = IC% - 1 : I = I + 1 : GOTO 12020
12090 RA% = IC% : RETURN
25000 REM (GOSUB 25010) RUN + AND - INSTRUCTIONS.
25010 NV% = CM%(CP%) + PM%(PP+1)
25013 REM HANDLES OVERFLOW.
25016 IF NV% < 0 THEN NV% = NV% + 256 : GOTO 25016
25018 IF NV% > 255 THEN NV% = NV% - 256 : GOTO 25018
25020 CM%(CP%) = NV% : RETURN
26000 REM (GOSUB 26010) RUN < AND > INSTRUCTIONS.
26010 CP% = CP% + PM%(PP+1)
26015 REM HANDLES OVERFLOW.
26020 IF CP% < 0   THEN CP% = 0 : RETURN 
26030 IF CP% > CC% THEN CP% = CC%
26040 RETURN
27000 REM (GOSUB 27010) RUNS [ INSTRUCTIONS.
27010 IF CM%(CP%) = 0 THEN PP = PM%(PP+1)
27020 RETURN
27500 REM (GOSUB 27510) RUNS ] INSTRUCTIONS.
27510 IF CM%(CP%) <> 0 THEN PP = PM%(PP+1)
27520 RETURN
28000 REM (GOSUB 28010) RUNS . INSTRUCTIONS.
28010 PRINT CHR$(CM%(CP%));
28020 RETURN
29000 REM (GOSUB 29010) RUNS ; INSTRUCTIONS.
29010 K$ = ""
29020 GET K$ : IF K$ = "" GOTO 29020
29025 K% = ASC(K$)
29028 IF K% = 133 THEN PP = PS% + 1 : GOTO 29040
29030 CM%(CP%) = K%
29040 RETURN
30000 REM (GOSUB 30010) RUNS ( AND ) INSTRUCTIONS.
30010 AP = AP + PM%(PP+1)
30015 REM HANDLES OVERFLOW.
30020 IF AP < 0  THEN AP = 0 : RETURN 
30030 IF AO > 65535 THEN AP = 65535
30040 RETURN
31000 REM (GOSUB 31010) RUNS @ INSTRUCTIONS.
31010 CM%(CP%) = PEEK(AP)
31020 RETURN
31500 REM (GOSUB 31510) RUNS * INSTRUNCTIONS
31510 POKE AP, CM%(CP%)
31520 RETURN