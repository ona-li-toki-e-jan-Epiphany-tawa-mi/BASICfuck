10 CC% = 15000 - 1 : DIM CM%(CC%) : REM CELL MEMORY & SIZE.
19 PS% = 510 - 1 : DIM PM%(PS%) : REM PROGRAM MEMORY & SIZE.
30 CP% = 0 : AP = 0 : REM CELL & C64 MEMORY POINTERS.
35 REM STARTUP MESSAGE.
38 PRINT CHR$(147); "BASICFUCK C64 BRAINFUCK REPL V1.0", "TYPE ? FOR HELP."
50 PRINT "TYPE ! TO EXIT."
65 REM (GOTO 70) INPUT LOOP.
70 INPUT "$"; IN$ : IF IN$ = "" THEN GOSUB 2010 : GOTO 70
80 FC$ = LEFT$(IN$, 1) : IF FC$ = "!" THEN END
100 IF FC$ = "?" THEN GOSUB 1010 : GOTO 70
110 REM CODE PARSING.
115 PP = 0 : IS% = LEN(IN$) : REM PROGRAM POINTER & INPUT SIZE.
120 FOR I = 1 TO IS% : C% = ASC(MID$(IN$, I, 1))
140 IF C% = 43 THEN RA%=43:RB%=45:RC%=1:GOSUB13010 : GOTO 215 : REM +
150 IF C% = 45 THEN RA%=43:RB%=45:RC%=1:GOSUB13010 : GOTO 215 : REM -
160 IF C% = 60 THEN RA%=62:RB%=60:RC%=2:GOSUB13010 : GOTO 215 : REM <
170 IF C% = 62 THEN RA%=62:RB%=60:RC%=2:GOSUB13010 : GOTO 215 : REM >
180 IF C% = 91 THEN PM%(PP) = 3 : PP = PP + 2      : GOTO 215 : REM [
190 IF C% = 93 THEN PM%(PP) = 4 : PP = PP + 2      : GOTO 215 : REM ]
200 IF C% = 46 THEN PM%(PP) = 5 : PP = PP + 2      : GOTO 215 : REM .
210 IF C% = 59 THEN PM%(PP) = 6 : PP = PP + 2      : GOTO 215 : REM ;
211 IF C% = 40 THEN RA%=41:RB%=40:RC%=7:GOSUB13010 : GOTO 215 : REM (
212 IF C% = 41 THEN RA%=41:RB%=40:RC%=7:GOSUB13010 : GOTO 215 : REM )
213 IF C% = 64 THEN PM%(PP) = 8 : PP = PP + 2      : GOTO 215 : REM @
214 IF C% = 42 THEN PM%(PP) = 9 : PP = PP + 2      : GOTO 215 : REM *
215 NEXT I
220 IF PP < PS% THEN PM%(PP) = 0
225 REM SECOND PASS FOR PARSING JUMP POINTS.
228 F% = 0  : REM FAIL FLAG FOR UNTERMINATED LOOPS.
232 FOR PP = 0 TO PS% STEP 2
235 IN% = PM%(PP) : IF IN% = 0 THEN PP = PS% + 1 : GOTO 260
250 IF IN% = 3 OR IN% = 4 THEN GOSUB 10010
255 IF F% THEN PP = PS% + 1
260 NEXT PP
270 IF F% THEN PRINT "?UNTERMINATED LOOP" : GOTO 70
310 REM INTERPRETER.
315 K$ = "" : FOR PP = 0 TO PS% STEP 2
325 GET K$ : IF K$ <> "" THEN IF ASC(K$) = 133 THEN PP = PS% + 1 : GOTO 410
330 ON PM%(PP) GOTO 350, 360, 370, 380, 390, 400, 405, 408, 409
340 PP = PS% + 1          : GOTO 410
350 GOSUB 25010           : GOTO 410 : REM + & -
360 GOSUB 26010           : GOTO 410 : REM < & >
370 GOSUB 27010           : GOTO 410 : REM [
380 GOSUB 27510           : GOTO 410 : REM ]
390 PRINT CHR$(CM%(CP%)); : GOTO 410 : REM .
400 GOSUB 29010           : GOTO 410 : REM ;
405 GOSUB 30010           : GOTO 410 : REM ( & )
408 CM%(CP%) = PEEK(AP)   : GOTO 410 : REM @
409 POKE AP, CM%(CP%)     : GOTO 410 : REM *
410 NEXT PP
420 GOSUB 2010 : GOTO 70
1000 REM (GOSUB 1010) HELP MESSAGES.
1010PRINT" ! EXITS THE REPL. ? DISPLAYS HELP INFORMATION.":PRINT"THE PREVIOUS ";
1020PRINT"TWO COMMANDS MUST BE THE FIRST CHARACTER IN INPUT TO FUNCTION."
1030PRINT" +/- INCREMENTS/DECREMENTS THE CURRENT CELL.":PRINT" </> MOVES THE M";
1040PRINT"EMORY POINTER TO THE LEFT/RIGHT.":PRINT" [ JUMPS PAST THE CORRESPOND";
1050PRINT"ING ] IF THE CURRENT CELL IS 0.":PRINT" ] JUMPS TO THE CORRESPONDING";
1060PRINT" [ IF THE CURRENT CELL IS NOT 0.":PRINT" . PRINTS THE VALUE OF THE C";
1070PRINT"URRENT CELL AS A CHARACTER.":PRINT" ; TAKES ONE CHARACTER FROM THE K";
1080PRINT"EYBOARD AS INPUT AND STORES IT INTO THE CURRENT CELL.":PRINT" (/) MO";
1090PRINT"VES THE C64 MEMORY POINTER TO THE LEFT/RIGHT.":PRINT" @ READS THE VA";
1100PRINT"LUE FROM C64 MEMORY INTO THE CURRENT CELL.":PRINT" * PUTS THE VALUE ";
1110PRINT"OF THE CURRENT CELL INTO C64 MEMORY." : RETURN
2000 REM (GOSUB 2010) PRINT CURRENT CELL.
2010 PRINT CM%(CP%);"(CELL";CP%;", $";AP;")"
2020 RETURN
10000 REM (GOSUB 10010) MAKE [ AND ] INSTRUCTIONS.
10010 B% = IN% : IF B% = 3 THEN OB% = 4 : K = 2 : GOTO 10016
10013 OB% = 3 : K = -2  : REM OTHER BRACKET & INPUT ITERATOR STEP.
10016 PP% = PP : D% = 0 : REM CURRENT LOOP DEPTH.
10020 PP% = PP% + K : IF PP% > PS% OR PP% < 0 THEN F% = -1 : RETURN
10030 IN% = PM%(PP%) : IF IN% = 0 THEN F% = -1 : RETURN
10040 IF IN% = B% THEN D% = D% + 1 : GOTO 10020
10050 IF IN% <> OB% GOTO 10020
10060 IF D% > 0 THEN D% = D% - 1 : GOTO 10020
10070 PM%(PP+1) = PP% : RETURN
12000 REM (GOSUB 12010) COUNT CHARACTERS +/-. RA% IS THE + CHAR., RB% IS -. 
12005 REM RESULT IS RA%.
12010 IC% = 0 
12020 IF I > IS% THEN RA% = IC% : I = I - 1 : RETURN
12030 C%=ASC(MID$(IN$,I,1)) : IF C%=RA% THEN IC%=IC%+1 : I=I+1 : GOTO 12020
12040 IF C% = RB% THEN IC% = IC% - 1 : I = I + 1 : GOTO 12020
12050 RA% = IC% : I = I - 1 : RETURN
13000 REM (GOSUB 13010) MAKES +/- COUNTED INSTRUCTIONS. RA% & RB% ARE THE +/- 
13005 REM CHARACTERS. RC% IS THE TYPE.
13010 GOSUB 12010 : IF RA% = 0 THEN RETURN
13020 PM%(PP) = RC% : PM%(PP+1) = RA% : PP = PP + 2 : RETURN
25000 REM (GOSUB 25010) RUN + & - INSTRUCTIONS.
25010 NV% = CM%(CP%) + PM%(PP+1)
25013 REM HANDLES OVERFLOW.
25016 IF NV% < 0 THEN NV% = NV% + 256 : GOTO 25016
25018 IF NV% > 255 THEN NV% = NV% - 256 : GOTO 25018
25020 CM%(CP%) = NV% : RETURN
26000 REM (GOSUB 26010) RUN < & > INSTRUCTIONS.
26010 CP% = CP% + PM%(PP+1) : IF CP% < 0 THEN CP% = 0 : RETURN 
26030 IF CP% > CC% THEN CP% = CC%                     : RETURN
26040 RETURN
27000 REM (GOSUB 27010) RUNS [ INSTRUCTIONS.
27010 IF CM%(CP%) = 0 THEN PP = PM%(PP+1) : RETURN
27020 RETURN
27500 REM (GOSUB 27510) RUNS ] INSTRUCTIONS.
27510 IF CM%(CP%) <> 0 THEN PP = PM%(PP+1) : RETURN
27520 RETURN
29000 REM (GOSUB 29010) RUNS ; INSTRUCTIONS.
29010 K$ = ""
29020 GET K$ : IF K$ = "" GOTO 29020
29025 K% = ASC(K$) : IF K% = 133 THEN PP = PS% + 1 : RETURN
29030 CM%(CP%) = K% : RETURN
30000 REM (GOSUB 30010) RUNS ( & ) INSTRUCTIONS.
30010 AP = AP + PM%(PP+1) : IF AP < 0  THEN AP = 0 : RETURN 
30030 IF AO > 65535 THEN AP = 65535                : RETURN
30040 RETURN