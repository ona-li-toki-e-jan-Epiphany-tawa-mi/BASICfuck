10 DIM MEMRY%(14999)
20 MEMRYPTR%=0


100 PRINT CHR$(147);
110 PRINT "BASICFUCK C64 BRAINFUCK REPL V0.0"
120 PRINT "USE THE ? COMMAND FOR HELP."
130 PRINT "USE THE ! COMMAND TO EXIT."


200 INPUT "$";L$
210 PROGRAMPTR%=1
220 IF PROGRAMPTR%>LEN(L$) GOTO 500
230 INSN$=MID$(L$,PROGRAMPTR%,1)
240 IF INSN$="+" GOTO 1000
250 IF INSN$="-" GOTO 2000
260 IF INSN$="<" GOTO 3000
270 IF INSN$=">" GOTO 4000
280 IF INSN$="[" GOTO 5000
290 IF INSN$="]" GOTO 6000
300 IF INSN$="." GOTO 7000
310 IF INSN$=";" GOTO 8000
320 IF INSN$="?" GOTO 9000
330 IF INSN$="!" THEN END

400 PROGRAMPTR%=PROGRAMPTR%+1
410 GOTO 220

500 PRINT MEMRY%(MEMRYPTR%);"(CELL";MEMRYPTR%;")"
510 GOTO 200


990 REM +
1000 MEMRY%(MEMRYPTR%)=MEMRY%(MEMRYPTR%)+1
1005 IF MEMRY%(MEMRYPTR%)>127 THEN MEMRY%(MEMRYPTR%)=-128
1010 GOTO 400

1990 REM -
2000 MEMRY%(MEMRYPTR%)=MEMRY%(MEMRYPTR%)-1
2005 IF MEMRY%(MEMRYPTR%)<-128 THEN MEMRY%(MEMRYPTR%)=127
2010 GOTO 400

2990 REM <
3000 MEMRYPTR%=MEMRYPTR%-1
3010 IF MEMRYPTR%<0 THEN MEMRYPTR%=0
3020 GOTO 400

3990 REM >
4000 MEMRYPTR%=MEMRYPTR%+1
4010 IF MEMRYPTR%>14999 THEN MEMRYPTR%=14999
4020 GOTO 400

4990 REM [
5000 IF MEMRY%(MEMRYPTR%)<>0 GOTO 400
5010 DEPTH%=0
5020 PROGRAMPTR%=PROGRAMPTR%+1
5030 IF PROGRAMPTR%>LEN(L$) THEN PRINT "?UNTERMINATED LOOP" : GOTO 200
5040 INSN$=MID$(L$,PROGRAMPTR%,1)
5050 IF INSN$="[" THEN DEPTH%=DEPTH%+1 : GOTO 5020
5060 IF INSN$<>"]" GOTO 5020
5070 IF DEPTH%>0 THEN DEPTH%=DEPTH%-1 : GOTO 5020
5080 PROGRAMPTR%=PROGRAMPTR%+1
5090 GOTO 400

5990 REM ]
6000 IF MEMRY%(MEMRYPTR%)=0 GOTO 400
6010 DEPTH%=0
6020 PROGRAMPTR%=PROGRAMPTR%-1
6030 IF PROGRAMPTR%<1 THEN PRINT "?UNTERMINATED LOOP" : GOTO 200
6040 INSN$=MID$(L$,PROGRAMPTR%,1)
6050 IF INSN$="]" THEN DEPTH%=DEPTH%+1 : GOTO 6020
6060 IF INSN$<>"[" GOTO 6020
6070 IF DEPTH%>0 THEN DEPTH%=DEPTH%-1 : GOTO 6020
6080 GOTO 400

6990 REM .
7000 PRINT CHR$(MEMRY%(MEMRYPTR%));
7010 GOTO 400

7990 REM ;
8000 POKE 19,1
8010 INPUT "";C$
8020 POKE 19,0
8030 IF C$="←" GOTO 8060
8040 MEMRY%(MEMRYPTR%)=ASC(C$)
8050 GOTO 400
8060 PRINT
8070 GOTO 500

8990 REM ?
9000 PRINT " ? DISPLAYS HELP INFORMATION."
9010 PRINT " ! EXITS THE REPL."
9020 PRINT " + INCREMENTS THE CURRENT CELL."
9030 PRINT " - DECREMENTS THE CURRENT CELL."
9040 PRINT " < MOVES THE CELL POINTER TO THE LEFT."
9050 PRINT " > MOVES THE CELL POINTER TO THE RIGHT."
9060 PRINT " [ JUMPS PAST THE CORRESPONDING ] IF THE CURRENT CELL IS 0."
9070 PRINT " ] JUMPS TO THE CORRESPONDING [ IF THE CURRENT CELL IS NOT 0."
9080 PRINT " . PRINTS THE CURRENT CELL'S VALUE AS AN ASCII CHARACTER."
9090 PRINT " ; TAKES A CHARACTER AS INPUT AND PUTS ITS CODE INTO THE CUR. CELL."
9100 GOTO 400